# AI Employee — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file (it is in .gitignore).

# ── Vault ──────────────────────────────────────────────────────────────────────
VAULT_PATH=./AI_Employee_Vault
DROP_PATH=./drop_folder

# ── Safety ─────────────────────────────────────────────────────────────────────
# Set to 'true' during development to prevent real external actions
DRY_RUN=false

# ── Scheduling ─────────────────────────────────────────────────────────────────
BRIEFING_HOUR=8

# ── Anthropic (for AI post generation) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Gmail Watcher (Silver Tier) ───────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# ── Email MCP Server (Silver Tier) ────────────────────────────────────────────
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── LinkedIn (Silver Tier) ────────────────────────────────────────────────────
LINKEDIN_EMAIL=you@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_SESSION_PATH=credentials/linkedin_session

# ── Facebook (Gold Tier — Browser Automation, no API needed) ──────────────────
# Uses Playwright — just your Facebook login + the URL of your Page
# No developer account, no app, no verification required
FACEBOOK_EMAIL=your_facebook_email@gmail.com
FACEBOOK_PASSWORD=your_facebook_password
FACEBOOK_PAGE_URL=https://www.facebook.com/yourpagename
FACEBOOK_SESSION_PATH=credentials/facebook_session

# ── Odoo (Gold Tier) ──────────────────────────────────────────────────────────
# Start with: docker compose up -d
# Then open http://localhost:8069 and create the database
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin

# PostgreSQL (used by docker-compose.yml)
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_secret

# ── WhatsApp (future) ─────────────────────────────────────────────────────────
# WHATSAPP_SESSION_PATH=/secure/path/to/session
