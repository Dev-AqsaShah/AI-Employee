# AI Employee — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file (it is in .gitignore).

# ── Vault ──────────────────────────────────────────────────────────────────────
VAULT_PATH=./AI_Employee_Vault
DROP_PATH=./drop_folder

# ── Safety ─────────────────────────────────────────────────────────────────────
# Set to 'true' during development to prevent real external actions
DRY_RUN=true

# ── Gmail Watcher (Silver tier) ───────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# ── Email MCP Server (Silver tier) ────────────────────────────────────────────
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Scheduling (Silver tier) ───────────────────────────────────────────────────
BRIEFING_HOUR=8

# ── Banking (Gold tier) ────────────────────────────────────────────────────────
# BANK_API_TOKEN=

# ── LinkedIn (Silver tier) ────────────────────────────────────────────────────
LINKEDIN_EMAIL=you@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_SESSION_PATH=credentials/linkedin_session

# ── WhatsApp (Silver tier) ─────────────────────────────────────────────────────
# WHATSAPP_SESSION_PATH=/secure/path/to/session

# ── Anthropic ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=   ← Claude Code reads this automatically; set via 'claude login'
